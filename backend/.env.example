# =============================================================================
# Doles Reels Generator - Backend Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Variables with defaults work out of the box with Docker Compose.
# Optional variables enable additional features; without them, services
# run in mock mode (returning sample/simulated data).
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Required - defaults work with Docker Compose)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:pass@postgres:5432/doles_reels

# -----------------------------------------------------------------------------
# Redis (Required - defaults work with Docker Compose)
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# Cloudflare R2 Storage (Optional - mock mode if not set)
# When not configured, the system simulates storage operations with fake URLs.
# Get credentials: https://dash.cloudflare.com/ -> R2 -> Create Bucket
# -----------------------------------------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=doles-reels
R2_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# R2_PUBLIC_URL=https://your-custom-domain.com    # Optional: custom domain

# -----------------------------------------------------------------------------
# Pexels Video API (Optional - mock mode if not set)
# When not configured, returns mock video clip metadata.
# Get a free key: https://www.pexels.com/api/
# -----------------------------------------------------------------------------
PEXELS_API_KEY=

# -----------------------------------------------------------------------------
# Anthropic Claude API (Optional - mock mode if not set)
# When not configured, returns preset vibe suggestions and sample keywords.
# Get a key: https://console.anthropic.com/
# Model used: claude-sonnet-4-20250514
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Application URLs (defaults work for local Docker development)
# -----------------------------------------------------------------------------
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
